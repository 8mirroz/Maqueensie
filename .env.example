# Knowledge Base environment template
# Copy to .env if you introduce runtime integrations.

# Optional: custom path to Obsidian vault root
KB_VAULT_ROOT=.

# Optional: current operator for logs/reports
KB_OPERATOR=market-intel-bot

# NotebookLM currently runs in manual mode in this repository.
# Keep empty unless a supported API integration is introduced in future.
NOTEBOOKLM_API_KEY=
